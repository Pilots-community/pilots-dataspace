# Copy to .env and fill in before running.
#
# The IP or hostname that OTHER machines will use to reach THIS machine.
# Must be routable from inside Docker containers — "localhost" will NOT work.
#
# Same network:       192.168.1.50         (LAN IP)
# Tailscale:          100.100.50.1         (Tailscale IP)
# Cloud / public IP:  203.0.113.42         (public IP)
# Single-machine test: 172.17.0.1          (Docker bridge gateway, Linux)
#                      host.docker.internal (Docker Desktop, macOS/Windows)
#
# Just the IP or hostname — no http:// prefix, no trailing slash.
MY_PUBLIC_HOST=

# Comma-separated list of ALL trusted issuer DIDs in the dataspace.
# Each machine's issuer DID is did:web:<host>%3A9876.
# Include EVERY machine (including this one).
#
# Example (two machines):
#   TRUSTED_ISSUER_DIDS=did:web:192.168.1.50%3A9876,did:web:192.168.1.51%3A9876
TRUSTED_ISSUER_DIDS=

# API key for management endpoints
EDC_API_KEY=password
